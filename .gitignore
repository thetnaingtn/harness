# Documentation: only root README.md and developer.md are tracked
*.md
!/README.md
!/developer.md

# Other prose/document formats
*.txt
*.rst
*.adoc
*.pdf
*.docx

# Go build artifacts
*.exe
*.test
*.out
*.prof
*.bench
# Compiled example binaries (Go puts the binary at examples/<name>/<name>)
/examples/*/[a-z]*-agent
/examples/minimal/minimal

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
*~

# Env
.env
.env.local
